# --- Paths that exist in this repo and must NOT ship in the VSIX ---

# Git / CI (repo-only)
.git/**
.github/**

# Source (runtime is out/extension.js only)
src/**

# Vendor sync script (dev only)
scripts/**

# Tooling configs (exist at repo root)
.gitignore
.vscodeignore
.editorconfig
.eslintignore
.eslintrc.cjs
jest.config.js
tsconfig.json
tsconfig.test.json
package-lock.json

# Extra docs (Marketplace keeps README.md, CHANGELOG.md, LICENSE)
ARCHITECTURE.md
CONTRIBUTING.md
SECURITY.md

# Dependencies are not packaged; webview assets are in resources/vendor/
node_modules/**
