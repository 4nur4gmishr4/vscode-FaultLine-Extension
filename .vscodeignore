# --- Repo paths that must NOT ship in the VSIX ---

.git/**
.github/**

# Source (runtime is out/extension.js)
src/**
scripts/**

# Tooling configs
.gitignore
.vscodeignore
.editorconfig
.eslintignore
.eslintrc.cjs
jest.config.js
tsconfig.json
tsconfig.test.json
package-lock.json

# Extra docs (Marketplace keeps README.md, CHANGELOG.md, LICENSE)
ARCHITECTURE.md
CONTRIBUTING.md
SECURITY.md
docs/**


# Dependencies not packaged; webview assets live in resources/vendor/
node_modules/**

# --- Generated during CI / local builds ---
# From: npm test -- --coverage (CI runs this before package)
coverage/**
# From: tsc incremental metadata under out/
**/.tsbuildinfo
out/**/*.map
out/**/*.test.js
out/**/*.spec.js

# Local package smoke leftovers (never ship)
_vsix_check/**
*.vsix
*.zip
