{
  "name": "fahh",
  "displayName": "FaultLine",
  "description": "Debugger and fault explainer for VS Code terminals and tasks. Optional sounds and notifications second.",
  "version": "3.5.0",
  "publisher": "4nur4gmishr4",
  "author": "Anurag Mishra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/4nur4gmishr4/vscode-FaultLine-Extension"
  },
  "bugs": {
    "url": "https://github.com/4nur4gmishr4/vscode-FaultLine-Extension/issues"
  },
  "homepage": "https://github.com/4nur4gmishr4/vscode-FaultLine-Extension#readme",
  "engines": {
    "vscode": "^1.93.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Debuggers",
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "FaultLine",
    "faultline",
    "fahh",
    "ai",
    "debugger",
    "fault explainer",
    "error",
    "terminal",
    "build",
    "sound",
    "audio",
    "notification",
    "webhook",
    "pii",
    "copilot",
    "fail"
  ],
  "icon": "resources/faultline-logo.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:faultline.test",
    "onCommand:faultline.testSuccess",
    "onCommand:faultline.toggle",
    "onCommand:faultline.toggleSounds",
    "onCommand:faultline.toggleWorkspace",
    "onCommand:faultline.selectSound",
    "onCommand:faultline.selectSoundFolder",
    "onCommand:faultline.resetSound",
    "onCommand:faultline.pickSoundPack",
    "onCommand:faultline.stop",
    "onCommand:faultline.snooze",
    "onCommand:faultline.showOutput",
    "onCommand:faultline.resetSettings",
    "onCommand:faultline.factoryReset",
    "onCommand:faultline.showWelcome",
    "onCommand:faultline.explainError",
    "onCommand:faultline.openSettings",
    "onCommand:faultline.testSound"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "faultline.test",
        "title": "%command.faultline.test%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.testSuccess",
        "title": "%command.faultline.testSuccess%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.toggle",
        "title": "%command.faultline.toggle%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.toggleSounds",
        "title": "%command.faultline.toggleSounds%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.toggleWorkspace",
        "title": "%command.faultline.toggleWorkspace%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.selectSound",
        "title": "%command.faultline.selectSound%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.selectSoundFolder",
        "title": "%command.faultline.selectSoundFolder%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.resetSound",
        "title": "%command.faultline.resetSound%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.pickSoundPack",
        "title": "%command.faultline.pickSoundPack%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.stop",
        "title": "%command.faultline.stop%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.snooze",
        "title": "%command.faultline.snooze%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.showOutput",
        "title": "%command.faultline.showOutput%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.resetSettings",
        "title": "%command.faultline.resetSettings%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.factoryReset",
        "title": "%command.faultline.factoryReset%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.showWelcome",
        "title": "%command.faultline.showWelcome%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.explainError",
        "title": "%command.faultline.explainError%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.openSettings",
        "title": "%command.faultline.openSettings%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.testSound",
        "title": "%command.faultline.testSound%",
        "category": "FaultLine"
      }
    ],
    "configuration": {
      "title": "%config.faultline.title%",
      "properties": {
        "faultline.soundPack": {
          "type": "string",
          "default": "faultline.mp3",
          "enum": [
            "faultline.mp3",
            "faultlinehard.mp3",
            "fartreverb.mp3",
            "faultlinedeep.mp3",
            "faultlinebroke.mp3",
            "ohshit.mp3"
          ],
          "enumDescriptions": [
            "Classic FaultLine (Default)",
            "Impact Strike",
            "Reverb Blast",
            "Deep Resonance",
            "System Crash",
            "Quick Expletive"
          ],
          "description": "Sound Pack to use for failure sounds"
        },
        "faultline.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable FaultLine extension"
        },
        "faultline.soundsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.faultline.soundsEnabled%"
        },
        "faultline.soundPath": {
          "type": "string",
          "default": "",
          "description": "Path to custom sound file",
          "scope": "machine-overridable"
        },
        "faultline.soundFolder": {
          "type": "string",
          "default": "",
          "description": "Folder containing random sound files",
          "scope": "machine-overridable"
        },
        "faultline.successEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable success sounds"
        },
        "faultline.successSound": {
          "type": "string",
          "default": "success_ding.mp3",
          "description": "%config.successSound.description%"
        },
        "faultline.volume": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "maximum": 100,
          "description": "%config.faultline.volume%"
        },
        "faultline.showNotification": {
          "type": "boolean",
          "default": true,
          "description": "%config.faultline.showNotification%"
        },
        "faultline.notificationLevel": {
          "type": "string",
          "default": "warning",
          "enum": [
            "info",
            "warning",
            "error",
            "none"
          ],
          "description": "%config.faultline.notificationLevel%"
        },
        "faultline.sources": {
          "type": "array",
          "default": [
            "task",
            "shell",
            "terminal"
          ],
          "description": "Sources to monitor for failures",
          "items": {
            "type": "string",
            "enum": [
              "task",
              "shell",
              "terminal",
              "diagnostics"
            ],
            "enumDescriptions": [
              "%config.faultline.sources.task%",
              "%config.faultline.sources.shell%",
              "%config.faultline.sources.terminal%",
              "%config.faultline.sources.diagnostics%"
            ]
          },
          "uniqueItems": true
        },
        "faultline.cooldownMs": {
          "type": "number",
          "default": 2000,
          "minimum": 0,
          "maximum": 60000,
          "description": "%config.faultline.cooldownMs%"
        },
        "faultline.cooldownPerSource": {
          "type": "boolean",
          "default": false,
          "description": "%config.faultline.cooldownPerSource%"
        },
        "faultline.maxPerMinute": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 120,
          "description": "%config.faultline.maxPerMinute%"
        },
        "faultline.ignorePatterns": {
          "type": "array",
          "default": [],
          "description": "%config.faultline.ignorePatterns%",
          "items": {
            "type": "string"
          }
        },
        "faultline.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "%config.faultline.showStatusBar%"
        },
        "faultline.statusBarCounter": {
          "type": "boolean",
          "default": true,
          "description": "%config.faultline.statusBarCounter%"
        },
        "faultline.flashStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "%config.faultline.flashStatusBar%"
        },
        "faultline.quietHours.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.faultline.quietHours.enabled%"
        },
        "faultline.quietHours.from": {
          "type": "string",
          "default": "22:00",
          "pattern": "^([01]?[0-9]|2[0-3]):([0-5][0-9])$",
          "description": "%config.faultline.quietHours.from%"
        },
        "faultline.quietHours.to": {
          "type": "string",
          "default": "08:00",
          "pattern": "^([01]?[0-9]|2[0-3]):([0-5][0-9])$",
          "description": "%config.faultline.quietHours.to%"
        },
        "faultline.muteWhenFocused": {
          "type": "boolean",
          "default": false,
          "description": "%config.faultline.muteWhenFocused%"
        },
        "faultline.snoozeMinutes": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 1440,
          "description": "%config.faultline.snoozeMinutes%"
        },
        "faultline.diagnosticsThreshold": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 100,
          "description": "%config.faultline.diagnosticsThreshold%"
        },
        "faultline.logLevel": {
          "type": "string",
          "default": "warn",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug"
          ],
          "description": "%config.faultline.logLevel%"
        },
        "faultline.historyMax": {
          "type": "number",
          "default": 50,
          "minimum": 10,
          "maximum": 500,
          "description": "%config.faultline.historyMax%"
        },
        "faultline.webhookUrl": {
          "type": "string",
          "default": "",
          "description": "%config.faultline.webhookUrl%",
          "scope": "machine",
          "pattern": "^$|^https://.+",
          "patternErrorMessage": "Webhook URL must start with https:// (or be empty to disable)."
        },
        "faultline.webhookAllowedDomains": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "%config.faultline.webhookAllowedDomains%",
          "scope": "machine"
        },
        "faultline.aiSummary.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.faultline.aiSummary.enabled%"
        },
        "faultline.aiProvider": {
          "type": "string",
          "default": "copilot",
          "enum": [
            "copilot",
            "openrouter",
            "groq",
            "gemini",
            "huggingface",
            "mistral",
            "together",
            "cohere",
            "openai",
            "anthropic"
          ],
          "enumDescriptions": [
            "GitHub Copilot (uses your existing Copilot subscription via VS Code Language Model API; no key required)",
            "OpenRouter (free Llama, Gemma, Mistral models; rate-limited)",
            "Groq (extremely fast inference; free tier with Llama, Gemma, Mixtral)",
            "Google Gemini (1500 req/day free on gemini-2.0-flash)",
            "Hugging Face (free inference API for open-source chat models)",
            "Mistral AI (free tier for open-mistral, ministral, Codestral)",
            "Together AI (free trial credit; 200+ open-source models)",
            "Cohere (free tier ~1000 req/month on Command R / R+)",
            "OpenAI (GPT-4o, GPT-4o-mini, GPT-3.5; pay per token)",
            "Anthropic Claude (3.5 Sonnet/Haiku/Opus; pay per token)"
          ],
          "description": "%config.faultline.aiProvider%"
        },
        "faultline.errorExplanation.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable error explanations"
        },
        "faultline.errorExplanation.autoShow": {
          "type": "boolean",
          "default": false,
          "description": "Auto-open AI error analysis on failure (off by default; uses Explain Error notification or command instead)"
        },
        "faultline.branchPatterns": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Git branch patterns to trigger on (empty = all branches). Supports glob patterns like 'main', 'feature/*', 'release/*'"
        },
        "faultline.jiraEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Create a Jira issue on failure (requires URL, project, email, and API key in SecretStorage)"
        },
        "faultline.jiraUrl": {
          "type": "string",
          "default": "",
          "description": "Jira instance URL (e.g., https://yourcompany.atlassian.net)"
        },
        "faultline.jiraProject": {
          "type": "string",
          "default": "",
          "description": "Jira project key (e.g., PROJ)"
        },
        "faultline.jiraEmail": {
          "type": "string",
          "default": "",
          "description": "Jira account email for API authentication"
        },
        "faultline.language": {
          "type": "string",
          "default": "en",
          "enum": [
            "en",
            "es",
            "fr",
            "de",
            "ja",
            "zh-CN",
            "zh-TW",
            "ko",
            "pt-BR",
            "ru",
            "it",
            "nl"
          ],
          "enumDescriptions": [
            "English",
            "Spanish",
            "French",
            "German",
            "Japanese",
            "Simplified Chinese",
            "Traditional Chinese",
            "Korean",
            "Portuguese (Brazil)",
            "Russian",
            "Italian",
            "Dutch"
          ],
          "description": "Interface language for the extension"
        },
        "faultline.webhookFormat": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "slack",
            "discord"
          ],
          "enumDescriptions": [
            "Default JSON format",
            "Slack webhook format",
            "Discord webhook format"
          ],
          "description": "Webhook payload format for notifications"
        },
        "faultline.ai.model": {
          "type": "string",
          "default": "meta-llama/llama-3.2-3b-instruct:free",
          "description": "The AI model to use for the selected provider (e.g., gpt-4o, gemini-1.5-pro)."
        }
      }
    }
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "vendor:sync": "node scripts/sync-vendor.js",
    "docs:gifs": "python scripts/make-docs-gifs.py",
    "vscode:prepublish": "npm run vendor:sync && npm run compile",
    "compile": "tsc -noEmit && esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
    "clean": "node -e \"require('fs').rmSync('out', {recursive: true, force: true})\" && node -e \"require('fs').rmSync('coverage', {recursive: true, force: true})\" && node -e \"try{require('fs').readdirSync('.').filter(f=>f.endsWith('.vsix')).forEach(f=>require('fs').rmSync(f))}catch(e){}\"",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "prebuild": "npm run clean",
    "build": "npm run compile",
    "package": "vsce package",
    "package:prod": "npm run clean && npm run vendor:sync && npm run compile && vsce package"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "18.x",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.9.2",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.11",
    "ts-morph": "^28.0.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "js-yaml": "^4.1.2"
  }
}
