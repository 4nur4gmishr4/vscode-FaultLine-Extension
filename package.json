{
  "name": "faultline",
  "displayName": "FaultLine",
  "description": "FaultLine (Previously FaultLine) - Intelligent auditory feedback for development failures.",
  "version": "3.0.0",
  "publisher": "FaultLine-Engineering",
  "author": "Anurag Mishra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/4nur4gmishr4/vscode-fahh-Extension"
  },
  "bugs": {
    "url": "https://github.com/4nur4gmishr4/vscode-fahh-Extension/issues"
  },
  "homepage": "https://github.com/4nur4gmishr4/vscode-fahh-Extension#readme",
  "engines": {
    "vscode": "^1.93.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "sound",
    "audio",
    "fail",
    "error",
    "notification",
    "build",
    "terminal"
  ],
  "icon": "resources/faultline-logo.jpeg",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "faultline.test",
        "title": "%command.faultline.test%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.testSuccess",
        "title": "%command.faultline.testSuccess%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.toggle",
        "title": "%command.faultline.toggle%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.toggleWorkspace",
        "title": "%command.faultline.toggleWorkspace%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.selectSound",
        "title": "%command.faultline.selectSound%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.selectSoundFolder",
        "title": "%command.faultline.selectSoundFolder%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.resetSound",
        "title": "%command.faultline.resetSound%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.pickSoundPack",
        "title": "%command.faultline.pickSoundPack%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.stop",
        "title": "%command.faultline.stop%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.snooze",
        "title": "%command.faultline.snooze%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.showOutput",
        "title": "%command.faultline.showOutput%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.resetSettings",
        "title": "%command.faultline.resetSettings%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.factoryReset",
        "title": "%command.faultline.factoryReset%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.showWelcome",
        "title": "%command.faultline.showWelcome%",
        "category": "FaultLine"
      },
      {
        "command": "faultline.explainError",
        "title": "FaultLine: Analyze Last Failure",
        "category": "FaultLine"
      },
      {
        "command": "faultline.openSettings",
        "title": "FaultLine: Open Configuration",
        "category": "FaultLine"
      },
      {
        "command": "faultline.testSound",
        "title": "%command.faultline.testSound%",
        "category": "FaultLine"
      }
    ],
    "walkthroughs": [
      {
        "id": "faultline.welcome",
        "title": "%walkthrough.faultline.title%",
        "description": "%walkthrough.faultline.description%",
        "steps": [
          {
            "id": "faultline.welcome.test",
            "title": "%walkthrough.faultline.step1.title%",
            "description": "%walkthrough.faultline.step1.description%",
            "media": {
              "markdown": "resources/step1.md"
            }
          },
          {
            "id": "faultline.welcome.sound",
            "title": "%walkthrough.faultline.step2.title%",
            "description": "%walkthrough.faultline.step2.description%",
            "media": {
              "markdown": "resources/step2.md"
            }
          },
          {
            "id": "faultline.welcome.configure",
            "title": "%walkthrough.faultline.step3.title%",
            "description": "%walkthrough.faultline.step3.description%",
            "media": {
              "image": "resources/settings.png",
              "altText": "FaultLine settings"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "%config.faultline.title%",
      "properties": {
        "faultline.soundPack": {
          "type": "string",
          "default": "faultline.mp3",
          "enum": [
            "faultline.mp3",
            "faultlinehard.mp3",
            "fartreverb.mp3",
            "faultlinedeep.mp3",
            "faultlinebroke.mp3",
            "ohshit.mp3"
          ],
          "enumDescriptions": [
            "Classic FaultLine (Default)",
            "Impact Strike",
            "Reverb Blast",
            "Deep Resonance",
            "System Crash",
            "Quick Expletive"
          ],
          "description": "Sound Pack to use for failure sounds"
        },
        "faultline.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable FaultLine extension"
        },
        "faultline.soundPath": {
          "type": "string",
          "default": "",
          "description": "Path to custom sound file",
          "scope": "machine-overridable"
        },
        "faultline.soundFolder": {
          "type": "string",
          "default": "",
          "description": "Folder containing random sound files",
          "scope": "machine-overridable"
        },
        "faultline.successEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable success sounds"
        },
        "faultline.successSound": {
          "type": "string",
          "default": "faultline.mp3",
          "description": "%config.successSound.description%"
        },
        "faultline.volume": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "maximum": 100,
          "description": "%config.faultline.volume%"
        },
        "faultline.showNotification": {
          "type": "boolean",
          "default": true,
          "description": "%config.faultline.showNotification%"
        },
        "faultline.notificationLevel": {
          "type": "string",
          "default": "warning",
          "enum": [
            "info",
            "warning",
            "error",
            "none"
          ],
          "description": "%config.faultline.notificationLevel%"
        },
        "faultline.sources": {
          "type": "array",
          "default": [
            "task",
            "shell",
            "terminal"
          ],
          "description": "Sources to monitor for failures",
          "items": {
            "type": "string",
            "enum": [
              "task",
              "shell",
              "terminal",
              "diagnostics",
              "build",
              "longTask"
            ],
            "enumDescriptions": [
              "%config.faultline.sources.task%",
              "%config.faultline.sources.shell%",
              "%config.faultline.sources.terminal%",
              "%config.faultline.sources.diagnostics%",
              "%config.faultline.sources.build%",
              "%config.faultline.sources.longTask%"
            ]
          },
          "uniqueItems": true
        },
        "faultline.cooldownMs": {
          "type": "number",
          "default": 5000,
          "minimum": 0,
          "maximum": 60000,
          "description": "%config.faultline.cooldownMs%"
        },
        "faultline.cooldownPerSource": {
          "type": "boolean",
          "default": false,
          "description": "%config.faultline.cooldownPerSource%"
        },
        "faultline.maxPerMinute": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 120,
          "description": "%config.faultline.maxPerMinute%"
        },
        "faultline.ignorePatterns": {
          "type": "array",
          "default": [],
          "description": "%config.faultline.ignorePatterns%",
          "items": {
            "type": "string"
          }
        },
        "faultline.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "%config.faultline.showStatusBar%"
        },
        "faultline.statusBarCounter": {
          "type": "boolean",
          "default": true,
          "description": "%config.faultline.statusBarCounter%"
        },
        "faultline.flashStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "%config.faultline.flashStatusBar%"
        },
        "faultline.quietHours.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.faultline.quietHours.enabled%"
        },
        "faultline.quietHours.from": {
          "type": "string",
          "default": "22:00",
          "pattern": "^([01]?[0-9]|2[0-3]):([0-5][0-9])$",
          "description": "%config.faultline.quietHours.from%"
        },
        "faultline.quietHours.to": {
          "type": "string",
          "default": "08:00",
          "pattern": "^([01]?[0-9]|2[0-3]):([0-5][0-9])$",
          "description": "%config.faultline.quietHours.to%"
        },
        "faultline.muteWhenFocused": {
          "type": "boolean",
          "default": false,
          "description": "%config.faultline.muteWhenFocused%"
        },
        "faultline.snoozeMinutes": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 1440,
          "description": "%config.faultline.snoozeMinutes%"
        },
        "faultline.diagnosticsThreshold": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 100,
          "description": "%config.faultline.diagnosticsThreshold%"
        },
        "faultline.longTaskThresholdMs": {
          "type": "number",
          "default": 60000,
          "minimum": 1000,
          "maximum": 3600000,
          "description": "%config.faultline.longTaskThresholdMs%"
        },
        "faultline.logLevel": {
          "type": "string",
          "default": "warn",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug"
          ],
          "description": "%config.faultline.logLevel%"
        },
        "faultline.historyMax": {
          "type": "number",
          "default": 50,
          "minimum": 10,
          "maximum": 500,
          "description": "%config.faultline.historyMax%"
        },
        "faultline.webhookUrl": {
          "type": "string",
          "default": "",
          "description": "%config.faultline.webhookUrl%",
          "scope": "machine",
          "pattern": "^$|^https?://.+",
          "patternErrorMessage": "Webhook URL must start with http:// or https:// (or be empty to disable)."
        },
        "faultline.webhookAllowedDomains": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "%config.faultline.webhookAllowedDomains%",
          "scope": "machine"
        },
        "faultline.aiSummary.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.faultline.aiSummary.enabled%"
        },
        "faultline.aiProvider": {
          "type": "string",
          "default": "copilot",
          "enum": [
            "copilot",
            "openrouter",
            "groq",
            "gemini",
            "huggingface",
            "mistral",
            "together",
            "cohere",
            "openai",
            "anthropic"
          ],
          "enumDescriptions": [
            "GitHub Copilot (uses your existing Copilot subscription via VS Code Language Model API; no key required)",
            "OpenRouter (free Llama, Gemma, Mistral models; rate-limited)",
            "Groq (extremely fast inference; free tier with Llama, Gemma, Mixtral)",
            "Google Gemini (1500 req/day free on gemini-2.0-flash)",
            "Hugging Face (free inference API for open-source chat models)",
            "Mistral AI (free tier for open-mistral, ministral, Codestral)",
            "Together AI (free trial credit; 200+ open-source models)",
            "Cohere (free tier ~1000 req/month on Command R / R+)",
            "OpenAI (GPT-4o, GPT-4o-mini, GPT-3.5; pay per token)",
            "Anthropic Claude (3.5 Sonnet/Haiku/Opus; pay per token)"
          ],
          "description": "%config.faultline.aiProvider%"
        },
        "faultline.dailySummary": {
          "type": "boolean",
          "default": false,
          "description": "Enable daily summary"
        },
        "faultline.streakCounter": {
          "type": "boolean",
          "default": false,
          "description": "Enable success streak counter"
        },
        "faultline.bossFightMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable boss fight mode"
        },
        "faultline.errorExplanation.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable error explanations"
        },
        "faultline.errorExplanation.autoShow": {
          "type": "boolean",
          "default": true,
          "description": "Auto-show error explanations on failure"
        },
        "faultline.branchPatterns": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Git branch patterns to trigger on (empty = all branches). Supports glob patterns like 'main', 'feature/*', 'release/*'"
        },
        "faultline.jiraUrl": {
          "type": "string",
          "default": "",
          "description": "Jira instance URL (e.g., https://yourcompany.atlassian.net)"
        },
        "faultline.jiraProject": {
          "type": "string",
          "default": "",
          "description": "Jira project key (e.g., PROJ)"
        },
        "faultline.jiraEmail": {
          "type": "string",
          "default": "",
          "description": "Jira account email for API authentication"
        },
        "faultline.language": {
          "type": "string",
          "default": "en",
          "enum": [
            "en",
            "es",
            "fr",
            "de",
            "ja",
            "zh-CN",
            "zh-TW",
            "ko",
            "pt-BR",
            "ru",
            "it",
            "nl"
          ],
          "enumDescriptions": [
            "English",
            "Spanish",
            "French",
            "German",
            "Japanese",
            "Simplified Chinese",
            "Traditional Chinese",
            "Korean",
            "Portuguese (Brazil)",
            "Russian",
            "Italian",
            "Dutch"
          ],
          "description": "Interface language for the extension"
        },
        "faultline.webhookFormat": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "slack",
            "discord"
          ],
          "enumDescriptions": [
            "Default JSON format",
            "Slack webhook format",
            "Discord webhook format"
          ],
          "description": "Webhook payload format for notifications"
        },
        "faultline.ai.model": {
          "type": "string",
          "default": "meta-llama/llama-3.2-3b-instruct:free",
          "description": "The AI model to use for the selected provider (e.g., gpt-4o, gemini-1.5-pro)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -noEmit && esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
    "clean": "node -e \"require('fs').rmSync('out', {recursive: true, force: true})\" && node -e \"require('fs').rmSync('coverage', {recursive: true, force: true})\" && node -e \"require('fs').rmSync('*.vsix', {force: true})\"",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "prebuild": "npm run clean && npm run lint",
    "build": "npm run compile",
    "package": "npx @vscode/vsce package",
    "package:prod": "npm run clean && npm run lint && npm run test && npm run compile && npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.1",
    "jest-environment-jsdom": "^30.3.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "js-yaml": "^4.1.2"
  },
  "localizations": {
